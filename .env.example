# Chave secreta da API da Anthropic (apenas no servidor, nunca enviada ao navegador)
ANTHROPIC_API_KEY=
# URL do projeto Supabase (publica, exposta ao navegador)
SUPABASE_URL=
# Chave anonima publica do Supabase (segura para o navegador)
SUPABASE_ANON_KEY=
# Porta do servidor (opcional, padrao 3000)
PORT=3000
